# ----- Database -----
# The bundled docker-compose Postgres is published on host port 5433
# (to avoid clashing with a locally-installed PostgreSQL on 5432).
DATABASE_URL="postgresql://erp:erp@localhost:5433/erp?schema=public"

# ----- API -----
PORT=3000
NODE_ENV=development
# comma-separated list of allowed web origins for CORS
CORS_ORIGINS="http://localhost:5173"

# ----- Auth (CHANGE THESE IN PRODUCTION) -----
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ----- Web (Vite) -----
VITE_API_URL="http://localhost:3000"
