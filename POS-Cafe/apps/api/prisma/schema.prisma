// =============================================================================
// Generic ERP Platform — Prisma schema (Phase 0 kernel + Phase 1 master data)
//
// Conventions (see docs/adr):
//  - Tenant tables carry `organizationId` (ADR-004). Tenancy is enforced in the
//    app layer by a Prisma Client Extension + AsyncLocalStorage context.
//  - Standard columns on business tables: id, organizationId, createdAt,
//    updatedAt, createdBy, updatedBy, deletedAt (soft delete).
//  - System/global tables (Organization, Permission, Currency) have NO
//    organizationId.
//  - Industry concepts (Student/Patient/...) do NOT appear here (ADR-008).
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------- Enums ----------------------------------------

enum OrganizationStatus {
  active
  suspended
  archived
}

enum PartnerStatus {
  active
  inactive
  archived
}

enum ProductType {
  stockable
  consumable
  service
  fee
  subscription
  asset
}

/// Per-product inventory costing policy (M3). AVCO is the Odoo-style default;
/// FIFO consumes batches in (expiry, received) order; STANDARD uses a fixed
/// Product.costPrice. See apps/api/src/modules/inventory/costing/.
enum CostingMethod {
  AVCO
  FIFO
  STANDARD
}

enum TaxType {
  vat
  gst
  sales_tax
  withholding
}

enum FiscalPeriodStatus {
  open
  closed
  locked
}

enum AddressType {
  billing
  shipping
  office
  branch
  home
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  approve
  reject
  post
  cancel
  receive
  issue
  adjust
  transfer
  // POS Tables Management (ADR-012)
  merge
  clean
  reserve
}

// ------------------------- System / global tables ---------------------------

/// Tenant root. This table IS the tenant, so it has no organizationId.
model Organization {
  id           String             @id @default(uuid())
  code         String             @unique
  name         String
  timezone     String             @default("UTC")
  currencyCode String             @default("USD")
  /// Phase C: FK to Currency for the org's base. Defaults to "USD" via seed.
  /// Renamed relation name avoids ambiguity with other Currency refs.
  baseCurrency Currency?         @relation("OrgBaseCurrency", fields: [currencyCode], references: [code])
  status       OrganizationStatus @default(active)
  settings     Json               @default("{}")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?
}

/// Global permission catalog (resource:action). Seeded from @erp/shared.
model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())
}

/// Global ISO-4217 currency catalog (ADR-004: currency is global).
model Currency {
  id            String   @id @default(uuid())
  code          String   @unique
  symbol        String
  name          String
  decimalPlaces Int      @default(2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  /// Phase C: this currency IS the org's base for these organizations.
  baseForOrganizations Organization[] @relation("OrgBaseCurrency")
  /// Phase C: FX rates where this currency is the FROM side.
  ratesFrom     CurrencyRate[] @relation("CurrencyRateFrom")
  /// Phase C: FX rates where this currency is the TO side.
  ratesTo       CurrencyRate[] @relation("CurrencyRateTo")
}

/// Phase C: FX rate between two currencies on a given date. Rates are
/// denominated in the TO currency per 1 unit of FROM currency. We use the
/// "as-of" lookup semantics: posting a 2024-01-15 invoice reads the rate
/// whose `asOf` is the most recent ≤ postingDate (per IFRS IAS 21).
model CurrencyRate {
  id             String   @id @default(uuid())
  fromCode       String
  toCode         String
  asOf           DateTime
  rate           Decimal  @db.Decimal(18, 8)
  /// Where this rate came from: 'manual' (operator entry), 'ecb' (European
  /// Central Bank daily reference), 'fed' (US Fed), 'import' (CSV upload).
  source         String   @default("manual")
  createdAt      DateTime @default(now())

  from           Currency @relation("CurrencyRateFrom", fields: [fromCode], references: [code], onDelete: Cascade)
  to             Currency @relation("CurrencyRateTo", fields: [toCode], references: [code], onDelete: Cascade)

  @@unique([fromCode, toCode, asOf])
  @@index([fromCode, toCode, asOf])
}

/// Phase C: unrealized FX gain/loss on monetary balances in foreign currency.
/// Written by `RevaluationService.runPeriod(periodId)` at period close.
model FxRevaluation {
  id             String   @id @default(uuid())
  organizationId String
  fiscalPeriodId String
  asOf           DateTime
  accountId      String
  currencyCode   String
  /// Book balance in the foreign currency.
  bookBalance    Decimal  @db.Decimal(20, 6)
  /// Balance valued at closing rate (in org base currency).
  revaluedBalance Decimal @db.Decimal(20, 6)
  /// Gain (positive) or loss (negative) posted to the FX adjustment account.
  fxGain         Decimal  @db.Decimal(20, 6)
  rate           Decimal  @db.Decimal(18, 8)
  createdAt      DateTime @default(now())

  @@unique([organizationId, fiscalPeriodId, accountId])
  @@index([organizationId, fiscalPeriodId])
}

// =============================================================================
// Phase D — Bank reconciliation
// =============================================================================

/// Bank statement imported from a CSV / MT940 / OFX file. Each row is a
/// single transaction on the bank side.
model BankStatementLine {
  id             String   @id @default(uuid())
  organizationId String
  bankAccountId  String   // -> BankAccount.id
  postedAt       DateTime
  /// Bank's reference (often a transaction ID, check #, etc.).
  externalRef    String?
  description    String
  /// Positive = money in, negative = money out (in the bank's currency).
  amount         Decimal  @db.Decimal(20, 6)
  currencyCode   String
  /// Status: 'unmatched' | 'matched' | 'ignored'.
  status         String   @default("unmatched")
  /// Linked payment (null until matched).
  matchedPaymentId String?
  /// Linked bank reconciliation run.
  matchedRunId   String?
  createdAt      DateTime @default(now())

  @@index([organizationId, bankAccountId, postedAt])
  @@index([status])
}

/// Reconciliation run — a single attempt to match a chunk of statement lines
/// against payments. Stores summary stats for audit.
model BankReconciliationRun {
  id             String   @id @default(uuid())
  organizationId String
  bankAccountId  String
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  matched        Int      @default(0)
  unmatched      Int      @default(0)
  totalAmount     Decimal  @db.Decimal(20, 6)
  notes          String?
  createdById    String?

  @@index([organizationId, bankAccountId, startedAt])
}

// ------------------------------- Auth / RBAC --------------------------------

model User {
  id           String    @id @default(uuid())
  organizationId String
  email        String
  passwordHash String
  firstName    String
  lastName     String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  /// Phase B1: TOTP secret (encrypted at rest with AES-256-GCM via the
  /// EncryptionService using a key derived from JWT_ACCESS_SECRET). `null`
  /// means MFA is not enrolled. The plaintext is never stored.
  mfaSecret    String?
  /// Phase B1: Initialization vector for the mfaSecret ciphertext (hex).
  mfaSecretIv  String?
  /// Phase B1: Auth tag for the mfaSecret ciphertext (hex).
  mfaSecretTag String?
  /// Phase B1: when MFA was enrolled. Used by the UI to show "MFA active since X".
  mfaEnrolledAt DateTime?
  /// Phase B1: number of consecutive failed login attempts. Reset on success.
  /// When ≥ 10, the account is locked and requires admin intervention.
  failedLoginCount Int    @default(0)
    /// Phase B1: when the account was locked.
    lockedUntil  DateTime?
    /// POS Phase A: optional manager PIN hash (bcrypt). Lets a cashier trigger
    /// a manager override (`pos:override`) by entering the manager's email + PIN
    /// without exposing the manager's full login password. Null = no PIN set.
    pinHash      String?
    /// POS Phase A: salt rounds used for the PIN hash (recorded at set time so
    /// future rehashes can be triggered). Defaults handled at write time.
    pinHashRounds Int?
    /// Phase F: the user's home branch. Optional; null = access to all branches
    /// the org has marked "all-access". Used by branch-scoped queries.
    defaultBranchId String?
    createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  roles         Role[]         @relation("UserRoles")
  refreshTokens RefreshToken[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Role {
  id           String    @id @default(uuid())
  organizationId String
  name         String
  description  String?
  isSystem     Boolean   @default(false)
  permissions  String[]  @default([])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  users User[] @relation("UserRoles")

  @@unique([organizationId, name])
  @@index([organizationId])
}

model RefreshToken {
  id           String    @id @default(uuid())
  organizationId String
  userId       String
  tokenHash    String
  expiresAt    DateTime
  revokedAt    DateTime?
  /// D4-4: when this token is rotated, the new refresh token's id goes here.
  /// Allows audit chains ("this token replaced by X, which replaced by Y").
  replacedById String?
  /// Optional human-readable device label for the active-sessions UI.
  deviceLabel  String?
  /// IP and user-agent captured at login. Audit-friendly.
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, tokenHash])
  @@index([organizationId])
  @@index([userId])
}

/// Idempotency cache (M-Day1-2). Stores the response of money-mutating POSTs
/// keyed on the caller's `Idempotency-Key` header. A retry with the same key
/// + same body returns the cached response without re-running the handler,
/// preventing duplicate invoices / duplicate GL posts / duplicate stock issues.
model IdempotencyRecord {
  id             String   @id @default(uuid())
  organizationId String
  key            String
  requestHash    String
  method         String
  path           String
  statusCode     Int
  responseJson   Json
  /// `pending` while the handler is running; `completed` once we stored the
  /// response. A second request that finds `pending` returns 409 (the first
  /// request is still in flight).
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  completedAt    DateTime?

  @@unique([organizationId, key])
  @@index([organizationId, createdAt])
}

// ------------------------------- Kernel -------------------------------------

model AuditLog {
  id           String      @id @default(uuid())
  organizationId String
  entity       String
  entityId     String
  action       AuditAction
  oldValues    Json?
  newValues    Json?
  actorId      String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())

  @@index([organizationId, entity, entityId])
  @@index([organizationId, createdAt])
}

/// Phase B1: tracks every login attempt for brute-force detection and
/// forensic review. Persists even failed attempts.
model LoginAttempt {
  id           String   @id @default(uuid())
  organizationId String?
  email        String
  success      Boolean
  /// When MFA was required but not yet verified.
  mfaRequired  Boolean  @default(false)
  ipAddress    String?
  userAgent    String?
  /// Failure reason if `success = false`.
  reason       String?
  createdAt    DateTime @default(now())

  @@index([email, createdAt])
  @@index([organizationId, createdAt])
  @@index([ipAddress, createdAt])
}

/// Settings at system (organizationId null), organization, or module scope.
model Setting {
  id           String   @id @default(uuid())
  organizationId String?
  scope        String   @default("organization")
  module       String?
  key          String
  value        Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([organizationId, scope, key])
  @@index([organizationId])
}

// ---------------------------- Master data -----------------------------------

model Partner {
  id           String        @id @default(uuid())
  organizationId String
  code         String
  name         String
  isCompany    Boolean       @default(false)
  isCustomer   Boolean       @default(false)
  isSupplier   Boolean       @default(false)
  isEmployee   Boolean       @default(false)
  email        String?
  phone        String?
  website      String?
  taxNumber    String?
  receivableAccountId String?
  payableAccountId    String?
  status       PartnerStatus @default(active)
  categoryId   String?
  notes        String?
  customFields Json          @default("{}")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  category  PartnerCategory? @relation(fields: [categoryId], references: [id])
  contacts  Contact[]
  addresses Address[]
  documents Document[]
  payments  Payment[]
  purchaseOrders   PurchaseOrder[]    @relation("PurchaseOrder_partner")
  purchaseRequests PurchaseRequest[]  @relation("PurchaseRequest_partner")
  debitNotes       DebitNote[]        @relation("DebitNote_partner")
  deals            Deal[]             @relation("PartnerDeals")
  activities       Activity[]         @relation("PartnerActivities")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, name])
}

model PartnerCategory {
  id           String    @id @default(uuid())
  organizationId String
  name         String
  parentId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  parent   PartnerCategory?  @relation("PartnerCategoryTree", fields: [parentId], references: [id])
  children PartnerCategory[] @relation("PartnerCategoryTree")
  partners Partner[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Contact {
  id           String    @id @default(uuid())
  organizationId String
  partnerId    String
  firstName    String
  lastName     String?
  position     String?
  email        String?
  phone        String?
  isPrimary    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([partnerId])
}

model Address {
  id           String      @id @default(uuid())
  organizationId String
  partnerId    String
  type         AddressType @default(billing)
  line1        String
  line2        String?
  city         String?
  state        String?
  postalCode   String?
  country      String?
  isPrimary    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([partnerId])
}

model Product {
  id           String      @id @default(uuid())
  organizationId String
  code         String
  sku          String?
  name         String
  description  String?
  productType  ProductType @default(stockable)
  costingMethod CostingMethod @default(AVCO)
  categoryId   String?
  uomId        String?
  taxId        String?
  salesPrice   Decimal?    @db.Decimal(18, 6)
  costPrice    Decimal?    @db.Decimal(18, 6)
  trackInventory Boolean   @default(true)
  batchTracking Boolean    @default(false)
  /// POS P5: which station (bar / kitchen / cafe) the KDS should route
  /// tickets for this product to. Required for the Kitchen Display System
  /// to fan out tickets to the right screens. NULL would mean "no KDS",
  /// which is uncommon - every sellable item goes somewhere.
  station      PosStation @default(cafe)
  minQuantity  Decimal     @default(0) @db.Decimal(20, 6)
  /// POS Phase P9: how the cashier flow handles an attempted sale that
  /// exceeds on-hand stock. Default 'silent' = current behaviour.
  stockPolicy    PosStockPolicy @default(silent)
  /// POS Phase P10: when true, the line's `unitPrice` is the GROSS amount
  /// (VAT included). The DocumentBuilderService splits it as
  ///   net = unitPrice / (1 + taxRate/100)
  ///   tax = unitPrice - net
  /// and the receipt prints "(incl. tax)" beside the line. The customer's
  /// menu still shows the same headline number; only the GL split changes.
  /// Default false (additive VAT) for backward compat.
  taxInclusive   Boolean     @default(false)
  isActive     Boolean     @default(true)
  customFields Json        @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  category ProductCategory? @relation(fields: [categoryId], references: [id])
  uom      UnitOfMeasure?   @relation(fields: [uomId], references: [id])
  tax      Tax?             @relation(fields: [taxId], references: [id])
  stockItems   StockItem[]
  stockBatches InventoryBatch[]
  stockLedger  InventoryLedger[]
  modifierGroups ProductModifierGroup[]
  comboItems    ComboItem[]
  menuProducts  MenuProduct[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, name])
}

model ProductCategory {
  id           String    @id @default(uuid())
  organizationId String
  name         String
  parentId     String?
  incomeAccountId  String?
  expenseAccountId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  parent   ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("ProductCategoryTree")
  products Product[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model UnitOfMeasure {
  id           String    @id @default(uuid())
  organizationId String
  code         String
  name         String
  category     String    @default("unit")
  ratio        Decimal   @default(1) @db.Decimal(18, 6)
  isBase       Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  products Product[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model Tax {
  id           String    @id @default(uuid())
  organizationId String
  name         String
  code         String?
  type         TaxType   @default(vat)
  rate         Decimal   @default(0) @db.Decimal(9, 6)
  isInclusive  Boolean   @default(false)
  isCompound   Boolean   @default(false)
  accountId    String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  products Product[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model FiscalPeriod {
  id           String             @id @default(uuid())
  organizationId String
  name         String
  startDate    DateTime
  endDate      DateTime
  status       FiscalPeriodStatus @default(open)
  /// D2-2: timestamp set by PeriodCloseService.close().
  closedAt     DateTime?
  /// User who closed the period.
  closedBy     String?
  /// D2-2: timestamp set by PeriodCloseService.lock(). After this point
  /// PostingService.assertOpen rejects any date in the period.
  lockedAt     DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Branch {
  id           String    @id @default(uuid())
  organizationId String
  code         String
  name         String
  timezone     String?
  isActive     Boolean   @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  purchaseOrders  PurchaseOrder[]    @relation("PurchaseOrder_branch")
  purchaseRequests PurchaseRequest[] @relation("PurchaseRequest_branch")
  goodsReceipts   GoodsReceiptNote[] @relation("GoodsReceipt_branch")

  @@unique([organizationId, code])
  @@index([organizationId])
}

// =============================================================================
// Phase 2 — General Ledger engine
// =============================================================================

enum AccountType {
  asset
  liability
  equity
  revenue
  expense
  cost_of_goods_sold
  bank
  cash
  receivable
  payable
  tax
  contra_asset
  contra_liability
}

enum JournalType {
  general
  sales
  purchase
  cash
  bank
  adjustment
  opening
  closing
}

enum JournalEntryStatus {
  draft
  posted
  reversed
}

/// Chart of accounts. `isGroup` accounts are summary nodes and cannot be posted to.
model Account {
  id              String      @id @default(uuid())
  organizationId  String
  code            String
  name            String
  accountType     AccountType
  parentAccountId String?
  currencyId      String?
  isGroup         Boolean     @default(false)
  isActive        Boolean     @default(true)
  description     String?
  /// M6 — Cash Flow classification (operating | investing | financing | null).
  /// Only meaningful for asset / liability / equity accounts; revenue and
  /// expense accounts are always operating.
  cashFlowCategory String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  createdBy       String?
  updatedBy       String?
  deletedAt       DateTime?

  parent        Account?       @relation("AccountTree", fields: [parentAccountId], references: [id])
  children      Account[]      @relation("AccountTree")
  journalLines  JournalLine[]
  documentLines DocumentLine[]
  bankAccount   BankAccount?   @relation("Account_bankAccount")
  cashRegisters CashRegister[] @relation("CashRegisterDefaultAccount")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, accountType])
}

model Journal {
  id                     String      @id @default(uuid())
  organizationId         String
  code                   String
  name                   String
  journalType            JournalType @default(general)
  defaultDebitAccountId  String?
  defaultCreditAccountId String?
  sequencePrefix         String?
  isActive               Boolean     @default(true)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  createdBy              String?
  updatedBy              String?
  deletedAt              DateTime?

  entries JournalEntry[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

/// Immutable once posted. Corrections are made via reversing entries (ADR-009).
model JournalEntry {
  id              String             @id @default(uuid())
  organizationId  String
  journalId       String
  entryNumber     String
  postingDate     DateTime
  description     String?
  status          JournalEntryStatus @default(draft)
  currencyId      String?
  sourceType      String?
  sourceId        String?
  reversedEntryId String? // the reversal entry that voids this one
  reversalOfId    String? // set when this entry IS a reversal of another
  postedAt        DateTime?
  postedBy        String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       String?

  journal Journal       @relation(fields: [journalId], references: [id])
  lines   JournalLine[]

  @@unique([organizationId, entryNumber])
  @@index([organizationId])
  @@index([organizationId, postingDate])
  @@index([sourceType, sourceId])
}

model JournalLine {
  id             String   @id @default(uuid())
  organizationId String
  journalEntryId String
  accountId      String
  partnerId      String?
  description    String?
  debit          Decimal  @default(0) @db.Decimal(20, 6)
  credit         Decimal  @default(0) @db.Decimal(20, 6)
  currencyId     String?
  exchangeRate   Decimal  @default(1) @db.Decimal(18, 8)
  baseDebit      Decimal  @default(0) @db.Decimal(20, 6)
  baseCredit     Decimal  @default(0) @db.Decimal(20, 6)
  lineNumber     Int      @default(0)
  createdAt      DateTime @default(now())

  entry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([organizationId])
  @@index([journalEntryId])
  @@index([organizationId, accountId])
}

/// Org-level account determination defaults (key -> account). See ADR-009.
model AccountMapping {
  id             String    @id @default(uuid())
  organizationId String
  key            String
  accountId      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, key])
  @@index([organizationId])
}

/// Removed in D1-1 — replaced by Postgres-native SEQUENCE objects.
/// Sequence numbers are now generated via `SELECT nextval('seq_<orgId>_<key>')`
/// inside the active transaction (see kernel/sequence/sequence.service.ts).
/// This eliminates the row-level upsert race that could crash concurrent first-time
/// callers and removes the hot-row bottleneck under load.

model BankAccount {
  id             String    @id @default(uuid())
  organizationId String
  accountId      String    @unique
  name           String
  bankName       String?
  accountNumber  String?
  currencyId     String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?
  updatedBy      String?
  deletedAt      DateTime?

  /// Back-reference for `Account.bankAccount`.
  account Account? @relation("Account_bankAccount", fields: [accountId], references: [id], onDelete: Restrict)

  @@index([organizationId])
}

// =============================================================================
// Phase 3 — Document framework + Accounts Receivable
// =============================================================================

enum DocumentType {
  sales_invoice
  credit_note
  vendor_bill
  debit_note
  proforma_invoice
}

enum DocumentStatus {
  draft
  submitted
  approved
  posted
  paid
  cancelled
}

enum PaymentStatus {
  not_paid
  partial
  paid
  overpaid
}

enum PaymentDirection {
  inbound
  outbound
}

/// Universal financial document. POS/School/Hotel etc. create these; the
/// accounting engine posts them. Residual lives here (NOT a separate ledger).
model Document {
  id                 String         @id @default(uuid())
  organizationId     String
  documentNumber     String
  documentType       DocumentType   @default(sales_invoice)
  partnerId          String
  currencyId         String?
  exchangeRate       Decimal        @default(1) @db.Decimal(18, 8)
  issueDate          DateTime
  dueDate            DateTime?
  status             DocumentStatus @default(draft)
  reference          String?
  notes              String?
  subtotal           Decimal        @default(0) @db.Decimal(20, 6)
  discountTotal      Decimal        @default(0) @db.Decimal(20, 6)
  taxAmount          Decimal        @default(0) @db.Decimal(20, 6)
  totalAmount        Decimal        @default(0) @db.Decimal(20, 6)
  amountPaid         Decimal        @default(0) @db.Decimal(20, 6)
  amountResidual     Decimal        @default(0) @db.Decimal(20, 6)
  paymentStatus      PaymentStatus  @default(not_paid)
  journalEntryId     String?
  reversedDocumentId String? // credit note -> original invoice
  /// Phase F: the branch this document was created from. Used by
  /// branch-scoped reports + permissions. Optional for backward compat.
  branchId           String?
  sourceType         String?
  sourceId           String?
  /// POS Tables (Phase T1): denormalised hot-path cache of which table this
  /// sale belongs to. Authoritative link is `PosTableOrder.documentId`; this
  /// column is kept in sync inside the same transaction so reporting queries
  /// (utilization / revenue) can GROUP BY table without joining.
  tableId            String?
  postedAt           DateTime?
  postedBy           String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  createdBy          String?
  updatedBy          String?

  partner     Partner             @relation(fields: [partnerId], references: [id])
  lines       DocumentLine[]
  allocations PaymentAllocation[]
  /// Back-reference for PosTableOrder.documentId. The FK is enforced from
  /// the PosTableOrder side (Document → PosTableOrder is a 1:N relation).
  posTableOrders PosTableOrder[]

  @@unique([organizationId, documentNumber])
  @@index([organizationId])
  @@index([organizationId, partnerId])
  @@index([organizationId, documentType, status])
  @@index([organizationId, branchId])
  @@index([organizationId, tableId])
}

model DocumentLine {
  id              String  @id @default(uuid())
  organizationId  String
  documentId      String
  productId       String?
  accountId       String?
  description     String
  quantity        Decimal @default(1) @db.Decimal(20, 6)
  unitPrice       Decimal @default(0) @db.Decimal(20, 6)
  discountPercent Decimal @default(0) @db.Decimal(9, 4)
  taxId           String?
  subtotal        Decimal @default(0) @db.Decimal(20, 6)
  taxAmount       Decimal @default(0) @db.Decimal(20, 6)
  total           Decimal @default(0) @db.Decimal(20, 6)
  lineNumber      Int     @default(0)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  account  Account? @relation(fields: [accountId], references: [id])

  @@index([organizationId])
  @@index([documentId])
}

// ============================================================================
// POS Phase A additions (sell loop): held orders / open tabs.
//
// A PosHold is a lightweight, parking-spot snapshot of a cart. The cashier
// builds lines, taps "Hold", and the cart is parked under a friendly name
// (e.g. "Sarah / table 3") until it's recalled and tendered. At recall time
// the POS vertical materialises the hold into a real `Document` (sales_invoice)
// + `Payment` through the existing `DocumentBuilderService` — no new money
// primitives are introduced.
//
// Lives next to `Document`/`DocumentLine` because that's the conceptual
// neighbourhood; not soft-deleted (status='open'|'recalled'|'cancelled' is the
// source of truth).
// ============================================================================

/// How a stockable product's POS behaves when the cart requests more units
/// than the warehouse has on hand. Read at checkout time by PosService.
///   block  — refuse the sale; the cashier must reduce the qty or re-stock.
///   warn   — allow the sale, but the response carries a low-stock warning
///            that the UI shows as a toast (Phase P9).
///   silent — allow the sale; the shortage is recorded in the inventory
///            dashboard and fixed up later (default for backward compat).
enum PosStockPolicy {
  block
  warn
  silent
}

enum PosHoldStatus {
  open
  recalled
  cancelled
}

model PosHold {
  id             String        @id @default(uuid())
  organizationId String
  /// Friendly name the cashier sees in the Open Tickets rail
  /// (e.g. "Sarah / table 3", "Order #14"). Not the same as a customer record.
  name           String
  /// Optional customer reference. If null we use the WALKIN partner at recall.
  partnerId      String?
  /// Optional branch and active cash session context, so we can filter "open
  /// holds on this register" quickly and stamp the recalled sale correctly.
  branchId       String?
  cashSessionId  String?
  /// Total pre-tax at park time. We recompute on recall because lines can be
  /// edited; the snapshot is for the rail's price preview.
  totalAmount    Decimal       @default(0) @db.Decimal(20, 6)
  status         PosHoldStatus @default(open)
  /// Free-form notes (e.g. "called away, will return").
  notes          String?
  heldById       String?
  recalledById   String?
  recalledAt     DateTime?
  cancelledById  String?
  cancelledAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  lines PosHoldLine[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, cashSessionId, status])
  @@index([organizationId, branchId, status])
}

model PosHoldLine {
  id              String  @id @default(uuid())
  organizationId  String
  holdId          String
  productId       String?
  description     String
  quantity        Decimal @default(1) @db.Decimal(20, 6)
  unitPrice       Decimal @default(0) @db.Decimal(20, 6)
  discountPercent Decimal @default(0) @db.Decimal(9, 4)
  taxId           String?
  lineNumber      Int     @default(0)
  /// Free-form note for kitchen/bar ("no sugar", "extra hot")
  note            String?

  hold PosHold @relation(fields: [holdId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([holdId])
}

// ============================================================================
// POS Phase D additions: Modifiers + Combos (P4) and KDS station routing (P5).
//
// Modifiers are add-ons for products (e.g. "Oat milk +UGX 700" on a latte).
// Combos are fixed meal deals (e.g. "Breakfast = Croissant + Latte for UGX 18k")
// that expand into their component lines on the receipt so inventory decrements
// per-component.
// ============================================================================

/// Which station should prepare this product. KDS (P5) routes tickets to the
/// right screen — drinks to the bar, food to the kitchen, pastries to the
/// cafe counter. Default 'cafe' so legacy products still get routed.
enum PosStation {
  bar
  kitchen
  cafe
}

model ModifierGroup {
  id             String   @id @default(uuid())
  organizationId String
  /// Display label, e.g. "Milk options", "Size", "Extras".
  name           String
  /// Customer must select at least this many modifiers. 0 = optional.
  minSelect      Int      @default(0)
  /// Max selections. 1 = radio, 2+ = checkbox.
  maxSelect      Int      @default(1)
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modifiers  Modifier[]
  products   ProductModifierGroup[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Modifier {
  id             String   @id @default(uuid())
  organizationId String
  groupId        String
  /// e.g. "Oat milk", "Extra shot", "Large".
  name           String
  /// Signed UGX added to the line price when this modifier is selected.
  /// Negative for "discount" modifiers (e.g. "No syrup" = -500).
  priceDelta     Decimal  @default(0) @db.Decimal(20, 6)
  isDefault      Boolean  @default(false)
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  group ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([groupId])
}

/// M-N: which modifier groups are available on a product. `sortOrder`
/// controls the order the cashier sees them in the AddOns dialog.
model ProductModifierGroup {
  id             String   @id @default(uuid())
  organizationId String
  productId      String
  modifierGroupId String
  sortOrder      Int      @default(0)

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([productId, modifierGroupId])
  @@index([organizationId])
}

/// A combo meal: a fixed set of products sold together for one price.
/// When the cashier sells a combo, pos.checkout expands it into one
/// DocumentLine per ComboItem so inventory still decrements per-component
/// (and the receipt shows every line item clearly).
model Combo {
  id             String   @id @default(uuid())
  organizationId String
  /// Display name, e.g. "Breakfast Deal", "Lunch Combo".
  name           String
  /// Fixed combo price in UGX.
  price          Decimal  @db.Decimal(20, 6)
  /// Optional short description shown on the menu card and receipt.
  description    String?
  isActive       Boolean  @default(true)
  /// Optional product image for the menu card.
  imageUrl       String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items ComboItem[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model ComboItem {
  id             String  @id @default(uuid())
  organizationId String
  comboId        String
  productId      String
  /// How many units of this product the combo includes (e.g. 1 croissant + 1 latte).
  quantity       Int     @default(1)

  combo   Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

@@unique([comboId, productId])
  @@index([organizationId])
  @@index([comboId])
}

// ============================================================================
// POS — Menu Management (per spec section #1).
//
// The spec distinguishes two concepts the existing schema collapsed into
// `Product`:
//   - Product    = master data (what's in inventory, costs, stockable).
//   - MenuItem   = what's on the menu / what customers order. Built from one
//                  or more products (a Cappuccino = 1 Espresso + 200ml Milk).
//                  Has its own price, image, prep time, availability.
// MenuCategory is an optional sub-tree grouping menu items inside the menu
// (e.g. "Hot Drinks", "Cold Drinks"). It sits *next to* ProductCategory —
// products stay organised by accounting/inventory concerns; menu items stay
// organised by what the customer sees.
//
// Customers never order Products directly — they order MenuItems. This module
// is the source of truth for the POS terminal's "menu" panel and for the
// digital-menu public catalog.
// ============================================================================

/// Optional sub-category for menu items. Independent from ProductCategory so
/// the menu presentation can be re-shaped without touching inventory/accounting.
model MenuCategory {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  /// Self-referencing tree so menu sections can nest (Drinks → Hot → Espresso-based).
  parentId       String?
  image          String?
  icon           String?
  displayOrder   Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parent   MenuCategory?  @relation("MenuCategoryTree", fields: [parentId], references: [id])
  children MenuCategory[] @relation("MenuCategoryTree")
  items    MenuItem[]

  @@unique([organizationId, name, parentId])
  @@index([organizationId])
  @@index([parentId])
}

/// What's actually sold to the customer. Built from one or more products via
/// MenuProduct (e.g. Cappuccino = Espresso ×1 + Milk ×200). Has its own price
/// which may differ from the sum of its product costs.
model MenuItem {
  id              String   @id @default(uuid())
  organizationId  String
  /// Optional: SKUs the cashier can punch in if the barcode scanner fires.
  code            String?
  name            String
  description     String?
  categoryId      String?
  /// Price the customer sees. Stored as Decimal(20,6) so it can be in any
  /// currency minor unit. NULL means "derive from MenuProduct sum" (rare).
  basePrice       Decimal? @db.Decimal(20, 6)
  image           String?
  /// Prep time hint for KDS — does not enforce anything, just a UI signal.
  preparationTime Int?
  isAvailable     Boolean  @default(true)
  displayOrder    Int      @default(0)
  /// Optional JSONB for chef-only notes, allergen tags, etc. Keeps the model
  /// flexible without forcing schema churn for every new attribute.
  customFields    Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category    MenuCategory?  @relation(fields: [categoryId], references: [id])
  ingredients MenuProduct[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([categoryId])
}

/// Join: how much of which Product goes into a MenuItem. One MenuItem can be
/// built from many Products (a combo-on-the-menu), and one Product can be in
/// many MenuItems (Espresso → Espresso, Cappuccino, Americano, Lungo…).
model MenuProduct {
  id             String  @id @default(uuid())
  organizationId String
  menuItemId     String
  productId      String
  /// Quantity of the product used per single sale of this menu item.
  /// For weight-based products (Milk 200ml) the Product's UoM carries the
  /// unit; this is a plain integer count.
  quantity       Decimal @default(1) @db.Decimal(20, 6)

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([menuItemId, productId])
  @@index([organizationId])
  @@index([productId])
}

// ============================================================================
// POS P5: KDS — Kitchen Display System.
//
// A KitchenTicket is created by pos.checkout (one per station) when a sale is
// tendered. Items list is denormalised (JSON) so the KDS can render the
// ticket without joining 4 tables per request. Lifecycle:
//   new → preparing → ready → served
// ============================================================================

enum KdsTicketStatus {
  new
  preparing
  ready
  served
  cancelled
}

model KitchenTicket {
  id             String          @id @default(uuid())
  organizationId String
  /// The originating sale. Multiple tickets (one per station) can point to the
  /// same invoice when a single sale has both bar and kitchen items.
  /// Nullable for pre-payment "Send To Kitchen" tickets.
  invoiceId      String?
  /// Human-readable label for the screen, e.g. "Order #42 — Sarah".
  label          String
  station        PosStation
  status         KdsTicketStatus @default(new)
  /// Denormalised items so the KDS renders without N+1 joins.
  items          Json
  /// When the kitchen started preparing this order.
  startedAt      DateTime?
  /// When the order was marked ready.
  readyAt        DateTime?
  /// When the runner / customer picked it up.
  servedAt       DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId, station, status])
  @@index([organizationId, createdAt])
  @@index([invoiceId])
}

// ============================================================================
// POS P7: Loyalty + Store Credit + Customer Tabs (the "membership economy").
//
//   LoyaltyProgram  — org-level config: 1 point per X UGX, 1 UGX per Y points.
//   LoyaltyLedger   — append-only point transactions (earn, redeem, expire, adjust).
//   StoreCredit     — partner-scoped balance (e.g. gift cards, refunds-to-credit).
//   StoreCreditLedger — append-only credit transactions.
//   CustomerTab     — running "house tab" for a regular, paid periodically.
//   CustomerTabLedger — append-only tab charges + payments.
//
// All five tables are org-scoped (added to ORG_SCOPED).
// ============================================================================

model LoyaltyProgram {
  id                String   @id @default(uuid())
  organizationId    String
  name              String
  /// E.g. 1 = 1 point per UGX spent. Use 0.01 for 1 point per 100 UGX.
  pointsPerCurrency Decimal  @default(1) @db.Decimal(20, 6)
  /// UGX value of a single point when redeeming. E.g. 100 = 1 point = UGX 100.
  currencyPerPoint  Decimal  @default(100) @db.Decimal(20, 6)
  /// Optional minimum points before a redemption is allowed.
  minPointsToRedeem Int      @default(50)
  /// Points expire after N days of inactivity. 0 = never.
  pointsExpireDays  Int      @default(365)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model LoyaltyLedger {
  id              String   @id @default(uuid())
  organizationId  String
  partnerId       String
  /// Earned (+) or redeemed (−) or adjusted manually.
  delta           Decimal  @db.Decimal(20, 6)
  /// Snapshot of the partner's running balance after this entry.
  balanceAfter    Decimal  @db.Decimal(20, 6)
  /// Earning source: the invoice (sale) that produced the points, or
  /// 'manual' for an admin adjustment, 'redemption' for a use, 'expire'.
  reason          String
  documentId      String?
  /// Optional: when the points expire (NULL = never).
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  createdBy       String?

  @@index([organizationId, partnerId, createdAt])
  @@index([organizationId, partnerId, reason])
  @@index([expiresAt])
}

model StoreCredit {
  id              String   @id @default(uuid())
  organizationId  String
  partnerId       String
  /// Signed balance. Positive = customer has credit; negative = customer
  /// owes the café (rare; usually we use CustomerTab for that).
  balance         Decimal  @default(0) @db.Decimal(20, 6)
  /// Optional: nil = never expires. Stale credit auto-forfeited via cron.
  expiresAt       DateTime?
  /// Optional: original source (refund id, gift-card purchase, etc.)
  source          String?
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ledger StoreCreditLedger[]

  @@unique([organizationId, partnerId])
  @@index([organizationId])
  @@index([organizationId, partnerId])
}

model StoreCreditLedger {
  id              String   @id @default(uuid())
  organizationId  String
  storeCreditId   String
  /// Positive = credit added; negative = credit used.
  delta           Decimal  @db.Decimal(20, 6)
  balanceAfter    Decimal  @db.Decimal(20, 6)
  /// E.g. 'refund', 'gift_card_purchase', 'sale', 'manual_adjust', 'expire'.
  reason          String
  documentId      String?
  createdAt       DateTime @default(now())
  createdBy       String?

  storeCredit StoreCredit @relation(fields: [storeCreditId], references: [id], onDelete: Cascade)

  @@index([organizationId, storeCreditId, createdAt])
}

model CustomerTab {
  id              String   @id @default(uuid())
  organizationId  String
  partnerId       String
  /// Signed running balance. Positive = customer owes this much.
  balance         Decimal  @default(0) @db.Decimal(20, 6)
  /// Max balance the customer is allowed to run. 0 = no limit.
  creditLimit     Decimal  @default(0) @db.Decimal(20, 6)
  /// Optional: link to a specific cash session so the cashier can settle
  /// the tab to a particular register at end of shift.
  cashSessionId   String?
  isOpen          Boolean  @default(true)
  openedAt        DateTime @default(now())
  closedAt        DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ledger CustomerTabLedger[]

  @@unique([organizationId, partnerId])
  @@index([organizationId])
}

model CustomerTabLedger {
  id              String   @id @default(uuid())
  organizationId  String
  tabId           String
  /// Positive = charge added to the tab; negative = payment received.
  delta           Decimal  @db.Decimal(20, 6)
  balanceAfter    Decimal  @db.Decimal(20, 6)
  reason          String
  /// For charges: the invoice that was added to the tab.
  /// For payments: the payment row that settled the tab.
  documentId      String?
  paymentId       String?
  createdAt       DateTime @default(now())
  createdBy       String?

  tab CustomerTab @relation(fields: [tabId], references: [id], onDelete: Cascade)

  @@index([organizationId, tabId, createdAt])
}

// ============================================================================
// Digital Menu (Phase 1 MVP) — customer-facing ordering channel.
//
// A MenuQrSession is the lightweight "we trust this device / this table" grant
// that the QR code encodes. It allows anonymous (no-login) orders on a
// specific table/branch for a limited window. The customer-facing menu page
// is a separate, no-auth route at /menu/:branchId/:tableId?token=xxx.
//
// OnlineOrder is the order a customer placed from the menu page. The cashier
// sees it as a normal Document (sales_invoice) on the terminal with
// sourceType='online_menu', and a KDS ticket is auto-created.
// ============================================================================

enum OnlineOrderStatus {
  received
  accepted
  preparing
  ready
  served
  completed
  cancelled
}

model MenuQrSession {
  id              String   @id @default(uuid())
  organizationId  String
  branchId        String
  /// Optional table number, e.g. "5" or "T-12". Free-form string.
  tableNumber     String?
  /// Short opaque token embedded in the QR URL. The customer-facing page
  /// passes it as ?token=... and the backend validates it.
  token           String   @unique
  expiresAt       DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  lastUsedAt      DateTime?

  orders OnlineOrder[]

  @@index([organizationId, branchId])
  @@index([organizationId, isActive])
}

model OnlineOrder {
  id              String           @id @default(uuid())
  organizationId  String
  /// The QR session that authorised this order. NULL = walk-in online.
  sessionId       String?
  /// Customer info captured during checkout (no auth required).
  customerName    String
  customerPhone   String?
  customerEmail   String?
  /// 'dine_in' | 'takeaway' | 'pickup' (digital menu: no delivery in MVP)
  orderType       String           @default("dine_in")
  /// Denormalised line items so the customer's tracking page renders
  /// without joining 4 tables per request.
  items           Json
  subtotal        Decimal          @db.Decimal(20, 6)
  taxAmount       Decimal          @default(0) @db.Decimal(20, 6)
  totalAmount     Decimal          @db.Decimal(20, 6)
  /// After the cashier settles the order, the resulting sales_invoice
  /// document id. NULL = not yet tendered (still in cart, or pending).
  invoiceId       String?
  /// 'mobile_money' | 'card' | 'cash_on_pickup' | 'wallet' | 'qr'
  paymentMethod   String?
  /// Raw mobile-money / card reference the customer supplied.
  paymentRef      String?
  status          OnlineOrderStatus @default(received)
  /// Free-form note from the customer ("no onions please", etc.)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  session MenuQrSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([organizationId, sessionId])
  @@index([organizationId, customerPhone])
}

model Payment {
  id                String           @id @default(uuid())
  organizationId    String
  paymentNumber     String
  direction         PaymentDirection @default(inbound)
  partnerId         String
  paymentDate       DateTime
  paymentMethod     String           @default("cash")
  journalId         String?
  accountId         String?
  currencyId        String?
  exchangeRate      Decimal          @default(1) @db.Decimal(18, 8)
  amount            Decimal          @default(0) @db.Decimal(20, 6)
  allocatedAmount   Decimal          @default(0) @db.Decimal(20, 6)
  unallocatedAmount Decimal          @default(0) @db.Decimal(20, 6)
  reference         String?
  status            DocumentStatus   @default(posted)
  /// Phase F: branch this payment was made at.
  branchId          String?
  journalEntryId    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  createdBy         String?
  updatedBy         String?

  partner     Partner             @relation(fields: [partnerId], references: [id])
  allocations PaymentAllocation[]
  cashMovements CashMovement[]

  @@unique([organizationId, paymentNumber])
  @@index([organizationId])
  @@index([organizationId, partnerId])
  @@index([organizationId, branchId])
}

model PaymentAllocation {
  id             String   @id @default(uuid())
  organizationId String
  paymentId      String
  documentId     String
  amount         Decimal  @default(0) @db.Decimal(20, 6)
  createdAt      DateTime @default(now())

  payment  Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id])

  @@index([organizationId])
  @@index([paymentId])
  @@index([documentId])
}

// =============================================================================
// Phase 4 — Inventory (stock of Products; optional batch/expiry, kept simple)
// =============================================================================

enum LocationType {
  warehouse
  store
  virtual
}

enum StockMoveType {
  receipt
  issue
  adjustment_in
  adjustment_out
  transfer_in
  transfer_out
  opening_balance
}

model InventoryLocation {
  id             String       @id @default(uuid())
  organizationId String
  code           String
  name           String
  type           LocationType @default(warehouse)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      String?
  updatedBy      String?
  deletedAt      DateTime?

  stockItems    StockItem[]
  batches       InventoryBatch[]
  ledgerEntries InventoryLedger[]
  cashRegisters CashRegister[]
  goodsReceipts GoodsReceiptNote[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

/// On-hand quantity per product per location (the "quant").
model StockItem {
  id             String   @id @default(uuid())
  organizationId String
  productId      String
  locationId     String
  quantity       Decimal  @default(0) @db.Decimal(20, 6)
  /// Running weighted-average cost per unit. Updated on every receipt (AVCO
  /// products only). For FIFO products this stays 0; for STANDARD products this
  /// stays 0 (the cost is Product.costPrice). See CostResolverService.
  runningAverageCost Decimal @default(0) @db.Decimal(20, 6)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product  Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  location InventoryLocation @relation(fields: [locationId], references: [id])

  @@unique([organizationId, productId, locationId])
  @@index([organizationId])
  @@index([productId])
  @@index([locationId])
}

/// Optional batch/lot with optional expiry — only used when product.batchTracking.
model InventoryBatch {
  id             String    @id @default(uuid())
  organizationId String
  productId      String
  locationId     String
  batchNumber    String
  quantity       Decimal   @default(0) @db.Decimal(20, 6)
  unitCost       Decimal?  @db.Decimal(20, 6)
  expiryDate     DateTime?
  receivedAt     DateTime  @default(now())
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  location      InventoryLocation @relation(fields: [locationId], references: [id])
  ledgerEntries InventoryLedger[]

  @@index([organizationId])
  @@index([productId, locationId])
  @@index([expiryDate])
}

/// Immutable stock ledger — every movement (receipt/issue/adjustment/transfer).
model InventoryLedger {
  id             String        @id @default(uuid())
  organizationId String
  ledgerCode     String
  productId      String
  locationId     String
  batchId        String?
  type           StockMoveType
  quantityChange Decimal       @db.Decimal(20, 6)
  balanceAfter   Decimal       @db.Decimal(20, 6)
  unitCost       Decimal       @default(0) @db.Decimal(20, 6)
  totalValue     Decimal       @default(0) @db.Decimal(20, 6)
  referenceType  String?
  referenceId    String?
  notes          String?
  performedBy    String?
  createdAt      DateTime      @default(now())

  product  Product           @relation(fields: [productId], references: [id])
  location InventoryLocation @relation(fields: [locationId], references: [id])
  batch    InventoryBatch?   @relation(fields: [batchId], references: [id])

  @@unique([organizationId, ledgerCode])
  @@index([organizationId])
  @@index([productId])
  @@index([locationId])
  @@index([organizationId, createdAt])
}

// =============================================================================
// M5 — Cash sessions / cash registers (foundation for POS + School canteen)
// =============================================================================

enum CashSessionStatus {
  open
  closed
  reconciled
}

enum CashMovementType {
  sale
  refund
  pay_in
  pay_out
  adjustment
}

/// Metadata about a till. `defaultAccountId` is the cash GL account used for
/// the session's opening float and movements. `locationId` is optional and
/// links the till to a physical InventoryLocation (e.g. a store).
model CashRegister {
  id             String    @id @default(uuid())
  organizationId String
  code           String
  name           String
  locationId     String?
  defaultAccountId String
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?
  updatedBy      String?
  deletedAt      DateTime?

  defaultAccount Account            @relation("CashRegisterDefaultAccount", fields: [defaultAccountId], references: [id])
  location       InventoryLocation? @relation(fields: [locationId], references: [id])
  sessions       CashSession[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([locationId])
}

/// An open shift at a CashRegister. `openingFloat` is the starting cash;
/// `closingCounted` is what was actually counted; `closingExpected` is what
/// the system computed (= opening + sales + pay-ins − pay-outs − refunds);
/// `closingDifference = counted − expected` and is the variance.
model CashSession {
  id                String           @id @default(uuid())
  organizationId    String
  cashRegisterId    String
  /// Phase F: redundant cache of the register's branch, for branch-scoped
  /// reports without joining back to the register.
  branchId          String?
  userId            String
  status            CashSessionStatus @default(open)
  openedAt          DateTime         @default(now())
  closedAt          DateTime?
  openingFloat      Decimal          @default(0) @db.Decimal(20, 6)
  closingCounted    Decimal?         @db.Decimal(20, 6)
  closingExpected   Decimal?         @db.Decimal(20, 6)
  closingDifference Decimal?         @db.Decimal(20, 6)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  cashRegister CashRegister   @relation(fields: [cashRegisterId], references: [id])
  movements    CashMovement[]

  @@index([organizationId])
  @@index([cashRegisterId])
  @@index([userId])
  @@index([status])
  @@index([organizationId, branchId])
}

/// Every in/out during a session. For sales/refunds the corresponding
/// `Payment` is linked via `paymentId` so the cash session reconciles with the
/// ledger.
model CashMovement {
  id             String          @id @default(uuid())
  organizationId String
  cashSessionId  String
  movementType   CashMovementType
  amount         Decimal         @db.Decimal(20, 6)
  paymentId      String?
  reason         String?
  performedBy    String?
  createdAt      DateTime        @default(now())

  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  payment     Payment?    @relation(fields: [paymentId], references: [id])

  @@index([organizationId])
  @@index([cashSessionId])
  @@index([paymentId])
}
// =============================================================================
// D3 � Reporting snapshots (Trial Balance / P&L / Balance Sheet / AP Aging)
// =============================================================================

/// Trial Balance snapshot. One row per (organization, asOf, account) carrying
/// the running debit / credit / balance from posted entries. Reports read from
/// this instead of live JournalLine so a 1M-row tenant returns in <500ms.
model ReportTrialBalanceSnapshot {
  id             String   @id @default(uuid())
  organizationId String
  asOf           DateTime
  accountId      String
  accountCode    String
  accountName    String
  accountType    String
  debit          Decimal  @db.Decimal(20, 6)
  credit         Decimal  @db.Decimal(20, 6)
  balance        Decimal  @db.Decimal(20, 6)
  builtAt        DateTime @default(now())

  @@unique([organizationId, asOf, accountId])
  @@index([organizationId, asOf])
}

/// Profit & Loss snapshot. One row per (organization, asOf) carrying the
/// revenue / contra-revenue / cogs / expense / net-income totals.
model ReportPnLSnapshot {
  id             String   @id @default(uuid())
  organizationId String
  asOf           DateTime
  revenue        Decimal  @db.Decimal(20, 6)
  contraRevenue  Decimal  @db.Decimal(20, 6)
  cogs           Decimal  @db.Decimal(20, 6)
  expense        Decimal  @db.Decimal(20, 6)
  netIncome      Decimal  @db.Decimal(20, 6)
  builtAt        DateTime @default(now())

  @@unique([organizationId, asOf])
  @@index([organizationId, asOf])
}

/// Balance Sheet snapshot. One row per (organization, asOf, account) carrying the
/// cumulative balance for balance-sheet accounts. Reports sum revenue/expense
/// lines through retained earnings automatically.
model ReportBalanceSheetSnapshot {
  id             String   @id @default(uuid())
  organizationId String
  asOf           DateTime
  accountId      String
  accountCode    String
  accountName    String
  accountType    String
  balance        Decimal  @db.Decimal(20, 6)
  builtAt        DateTime @default(now())

  @@unique([organizationId, asOf, accountId])
  @@index([organizationId, asOf])
}

/// AP Aging snapshot. One row per (organization, asOf, partner) with the unpaid
/// vendor-bill balances bucketed by age.
model ReportApAgingSnapshot {
  id             String   @id @default(uuid())
  organizationId String
  asOf           DateTime
  partnerId      String
  partnerName    String
  total          Decimal  @db.Decimal(20, 6)
  current        Decimal  @db.Decimal(20, 6)
  b1_30          Decimal  @db.Decimal(20, 6)
  b31_60         Decimal  @db.Decimal(20, 6)
  b61_90         Decimal  @db.Decimal(20, 6)
  b90p           Decimal  @db.Decimal(20, 6)
  builtAt        DateTime @default(now())

  @@unique([organizationId, asOf, partnerId])
  @@index([organizationId, asOf])
}

/// AR/AP tie-out snapshot � written nightly by TieOutService. Compares the GL
/// AR/AP control account balance to the sum of open invoice/bill residuals. A
/// variance > .01 means the books are out of sync.
model ReportTieoutSnapshot {
  id             String   @id @default(uuid())
  organizationId String
  asOf           DateTime
  arBalanced     Boolean
  arVariance     Decimal  @db.Decimal(20, 6)
  apBalanced     Boolean
  apVariance     Decimal  @db.Decimal(20, 6)
  arDetails      Json
  apDetails      Json
  builtAt        DateTime @default(now())

  @@unique([organizationId, asOf])
  @@index([organizationId, asOf])
}

// =============================================================================
// D4-3 — Transactional outbox for domain events
// =============================================================================

/// Outbox row written inside the same $transaction as the business write, so
/// events never get lost on commit failure and never fire on rollback. The
/// OutboxWorker polls pending rows and dispatches them to handlers.
model EventOutbox {
  id             String   @id @default(uuid())
  organizationId String
  eventName      String
  payload        Json
  status         String   @default("pending")
  attempts       Int      @default(0)
  lastError      String?
  /// D4-3 / Multi-instance safety: a uuid set by the worker when it claims a
  /// row. Two workers that read the same pending row will see the same claim
  /// token; the UPDATE ... WHERE claimToken = ? pattern guarantees only one
  /// wins. Cleared on success.
  claimToken     String?
  claimedAt      DateTime?
  createdAt      DateTime @default(now())
  shippedAt      DateTime?

  @@index([status, createdAt])
  @@index([organizationId, status])
}

// =============================================================================
// Phase F.5 — Notifications (in-app, email, SMS, push)
// =============================================================================

enum NotificationChannel {
  in_app
  email
  sms
  push
}

enum NotificationStatus {
  pending
  sent
  failed
  read
}

/// A user-facing notification. In-app notifications are always written; the
/// optional channel push is best-effort (worker dispatches email/SMS/push via
/// the configured provider).
model Notification {
  id             String              @id @default(uuid())
  organizationId String
  /// Null when the notification targets a whole org (e.g. system maintenance).
  userId         String?
  channel        NotificationChannel @default(in_app)
  category       String              @default("general")
  title          String
  body           String
  payload        Json                @default("{}")
  status         NotificationStatus  @default(pending)
  /// When the in-app notification was acknowledged.
  readAt         DateTime?
  /// When the channel delivery succeeded.
  sentAt         DateTime?
  /// Failure reason (provider response, etc.).
  error          String?
  createdAt      DateTime            @default(now())

  @@index([organizationId, userId, status, createdAt])
  @@index([status, createdAt])
  @@index([userId, readAt])
}

/// User-level notification preferences. Falls back to org defaults when
/// missing. Per-channel opt-out; per-category frequency caps.
model NotificationPreference {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  channel        NotificationChannel
  category       String              @default("general")
  enabled        Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([organizationId, userId, channel, category])
  @@index([organizationId])
}

// =============================================================================
// Phase F.5 — File storage abstraction
// =============================================================================

enum FileVisibility {
  private
  org
  public
}

/// Logical file record. The bytes live in the configured storage driver (local
/// disk in dev, S3-compatible in prod). Download is via short-lived signed URL.
model File {
  id             String         @id @default(uuid())
  organizationId String
  uploadedById   String?
  filename       String
  contentType    String
  byteSize       Int
  storageKey     String         @unique
  visibility     FileVisibility @default(private)
  /// Free-form owner pointer (e.g. "Partner:abc" or "Expense:xyz").
  ownerType      String?
  ownerId        String?
  checksum       String?
  /// Internal: encrypted-at-rest (provider-side or app-side).
  encrypted      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  deletedAt      DateTime?

  @@index([organizationId, ownerType, ownerId])
  @@index([organizationId, createdAt])
}

// =============================================================================
// Phase F.5 — Password reset / email verification
// =============================================================================

enum OneTimeTokenPurpose {
  password_reset
  email_verification
  invite
}

/// Generic one-time-use token with TTL. Replaces the previous "abuse of
/// IdempotencyRecord" pattern with a dedicated, typed table.
model OneTimeToken {
  id             String             @id @default(uuid())
  organizationId String?
  userId         String?
  /// SHA-256 hash of the presented token. The raw token is sent to the user.
  tokenHash      String             @unique
  purpose        OneTimeTokenPurpose
  expiresAt      DateTime
  consumedAt     DateTime?
  /// Optional context (e.g. IP that requested the reset).
  payload        Json               @default("{}")
  createdAt      DateTime           @default(now())

  @@index([userId, purpose])
  @@index([expiresAt])
}

// =============================================================================
// Phase F.5 — Approvals (generic, state machine driven)
// =============================================================================

enum ApprovalStatus {
  pending
  approved
  rejected
  cancelled
}

/// A request awaiting decision(s). Each ApprovalRequest can require N
/// approvals from N distinct approvers (e.g. 2-of-3). Configurable per
/// document type via ApprovalPolicy.
model ApprovalRequest {
  id              String         @id @default(uuid())
  organizationId  String
  /// What is being approved, e.g. "expense:123" or "vendor_bill:abc".
  entityType      String
  entityId        String
  /// Free-form snapshot for the UI (amount, partner, etc.).
  snapshot        Json
  policyId        String?
  status          ApprovalStatus @default(pending)
  requiredCount   Int            @default(1)
  decidedAt       DateTime?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  policy  ApprovalPolicy?     @relation(fields: [policyId], references: [id])
  decisions ApprovalDecision[]

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, status])
}

model ApprovalDecision {
  id             String         @id @default(uuid())
  organizationId String
  requestId      String
  approverId     String
  status         ApprovalStatus
  comment        String?
  decidedAt      DateTime       @default(now())

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, approverId])
  @@index([organizationId])
}

/// Per-org rules for which documents require approval, who decides, and how
/// many approvals are needed.
model ApprovalPolicy {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  entityType      String
  /// Optional amount threshold above which approval is required.
  minAmount       Decimal? @db.Decimal(20, 6)
  /// Permissions required to act as an approver.
  approverPermissions String[] @default([])
  requiredCount   Int      @default(1)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requests ApprovalRequest[]

  @@index([organizationId, entityType, isActive])
}

// =============================================================================
// Phase F.5 — Recurring documents (invoices / expenses)
// =============================================================================

enum RecurringFrequency {
  daily
  weekly
  monthly
  quarterly
  yearly
}

enum RecurringStatus {
  active
  paused
  ended
}

model RecurringDocument {
  id              String              @id @default(uuid())
  organizationId  String
  name            String
  /// sales_invoice | vendor_bill | credit_note
  documentType    DocumentType
  /// Template payload (partnerId, lines, etc.). Generated children copy from this.
  template        Json
  frequency       RecurringFrequency
  /// Next date a child should be generated (UTC midnight).
  nextRunAt       DateTime
  /// Last successfully generated child (for back-fill detection).
  lastRunAt       DateTime?
  endDate         DateTime?
  status          RecurringStatus     @default(active)
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  runs RecurringDocumentRun[]

  @@index([organizationId, status, nextRunAt])
}

model RecurringDocumentRun {
  id              String   @id @default(uuid())
  organizationId  String
  recurringId     String
  scheduledFor    DateTime
  /// When the worker actually ran this slot.
  ranAt           DateTime?
  documentId      String?  // -> Document.id when generated
  status          String   @default("pending") // pending | generated | failed | skipped
  error           String?

  recurring RecurringDocument @relation(fields: [recurringId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, scheduledFor])
  @@unique([recurringId, scheduledFor])
}

// =============================================================================
// Phase F.5 — Outbound webhooks
// =============================================================================

enum WebhookEventStatus {
  pending
  succeeded
  failed
  dead
}

/// Outbound webhook delivery. Signed (HMAC-SHA256) so receivers can verify
/// origin. Retries with exponential backoff up to N attempts.
model WebhookEndpoint {
  id             String   @id @default(uuid())
  organizationId String
  url            String
  /// Events to subscribe to. Empty array = all events.
  events         String[] @default([])
  /// HMAC secret used to sign deliveries (rotated by creating a new endpoint).
  signingSecret  String
  isActive       Boolean  @default(true)
  description    String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  deliveries WebhookDelivery[]

  @@index([organizationId, isActive])
}

model WebhookDelivery {
  id             String             @id @default(uuid())
  organizationId String
  endpointId     String
  eventName      String
  payload        Json
  status         WebhookEventStatus @default(pending)
  attempts       Int                @default(0)
  lastAttemptAt  DateTime?
  nextAttemptAt  DateTime?
  succeededAt    DateTime?
  responseStatus Int?
  responseBody   String?
  error          String?

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, nextAttemptAt])
  @@index([endpointId])
}

// =============================================================================
// Phase F.5 — Per-tenant feature flags
// =============================================================================

/// Sparse flag table: a row exists only when the flag is explicitly enabled.
/// Absence = default (off). The vertical scaffolding sets these per tenant
/// during onboarding or via the in-app "Modules" page.
model FeatureFlag {
  id             String   @id @default(uuid())
  organizationId String
  key            String
  enabled        Boolean  @default(true)
  /// Optional JSON payload (e.g. limit overrides).
  payload        Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
}

// =============================================================================
// Phase F.5 — Saved reports / scheduled report runs
// =============================================================================

model SavedReport {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  /// e.g. "trial-balance", "ar-aging", "profit-and-loss".
  reportKey      String
  /// Free-form parameter snapshot (period, accountIds, etc.).
  parameters     Json     @default("{}")
  schedule       String?  // cron expression, optional
  /// CSV | PDF | both.
  format         String   @default("csv")
  emailTo        String[] @default([])
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  runs SavedReportRun[]

  @@index([organizationId, reportKey])
}

model SavedReportRun {
  id             String   @id @default(uuid())
  organizationId String
  reportId       String
  scheduledFor   DateTime
  ranAt          DateTime?
  status         String   @default("pending") // pending | running | succeeded | failed
  fileId         String?  // -> File.id (CSV or PDF)
  error          String?

  report SavedReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, scheduledFor])
}

// =============================================================================
// Phase F.5 — Vertical module enablement per organization
// =============================================================================

model OrganizationModule {
  id             String   @id @default(uuid())
  organizationId String
  moduleName     String   // 'pos' | 'school' | 'hospital' | …
  isActive       Boolean  @default(true)
  /// Per-tenant config (e.g. POS: enableTips, school: enableBoarding).
  config         Json     @default("{}")
  enabledAt      DateTime @default(now())
  disabledAt     DateTime?

  @@unique([organizationId, moduleName])
  @@index([organizationId, isActive])
}

// =============================================================================
// Phase F.6 — Procurement chain (PR → RFQ → PO → GRN → Bill)
// =============================================================================

enum PurchaseRequestStatus {
  draft
  submitted
  approved
  rejected
  cancelled
  converted  // converted to one or more POs
}

enum PurchaseOrderStatus {
  draft
  submitted
  approved
  sent       // sent to supplier
  acknowledged
  partially_received
  received
  billed
  closed
  cancelled
}

enum GoodsReceiptStatus {
  draft
  posted
  cancelled
}

enum MatchStatus {
  pending
  matched
  partial
  mismatch
  blocked
}

enum DebitNoteReason {
  price_adjustment
  returned_goods
  overcharge
  correction
  other
}

/// A request for goods or services. Not a financial document — drives PO
/// creation once approved. May have multiple lines (product / qty / desired
/// delivery / estimated price). Workflow: draft → submitted → approved →
/// converted (to one or more POs).
model PurchaseRequest {
  id              String                @id @default(uuid())
  organizationId  String
  requestNumber   String
  requestedById   String?
  partnerId       String?  // preferred supplier (optional)
  branchId        String?
  description     String?
  neededBy        DateTime?
  status          PurchaseRequestStatus @default(draft)
  approvedAt      DateTime?
  approvedById    String?
  rejectedReason  String?
  /// Free-form JSON snapshot of the request at submit time (for audit).
  snapshot        Json?
  customFields    Json                  @default("{}")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?

  lines     PurchaseRequestLine[]
  orders    PurchaseOrder[]
  createdBy String?
  updatedBy String?

  partner Partner? @relation("PurchaseRequest_partner", fields: [partnerId], references: [id], onDelete: SetNull)
  branch  Branch?  @relation("PurchaseRequest_branch", fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([organizationId, requestNumber])
  @@index([organizationId, status])
  @@index([organizationId, neededBy])
}

model PurchaseRequestLine {
  id               String   @id @default(uuid())
  organizationId   String
  purchaseRequestId String
  productId        String?
  description      String
  quantity         Decimal  @db.Decimal(20, 6)
  unitOfMeasureId  String?
  estimatedUnitPrice Decimal? @db.Decimal(20, 6)
  notes            String?
  lineNumber       Int      @default(0)

  request PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([organizationId, purchaseRequestId])
}

/// A purchase order to a supplier. Once approved + sent, it cannot be edited —
/// corrections happen via new revisions. PO is the source of truth for
/// "what we agreed to receive"; the GRN records "what we actually received";
/// the bill records "what the supplier claims". Three-way match reconciles them.
model PurchaseOrder {
  id              String              @id @default(uuid())
  organizationId  String
  orderNumber     String
  partnerId       String
  branchId        String?
  description     String?
  orderDate       DateTime            @default(now())
  expectedDeliveryDate DateTime?
  currencyCode    String              @default("USD")
  exchangeRate    Decimal             @default(1) @db.Decimal(18, 8)
  subtotal        Decimal             @default(0) @db.Decimal(20, 6)
  taxAmount       Decimal             @default(0) @db.Decimal(20, 6)
  totalAmount     Decimal             @default(0) @db.Decimal(20, 6)
  status          PurchaseOrderStatus @default(draft)
  approvedAt      DateTime?
  approvedById    String?
  sentAt         DateTime?
  notes           String?
  terms           String?
  /// Free-form snapshot at approve/send for audit.
  snapshot        Json?
  customFields    Json                @default("{}")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  requestId       String?  // PR that drove this PO (nullable: ad-hoc POs allowed)
  parentOrderId   String?  // revision chain

  lines        PurchaseOrderLine[]
  receipts     GoodsReceiptNote[]
  bills        VendorBillLink[]    // via join table to support multiple partial bills
  matchStatuses ThreeWayMatch[]
  createdBy    String?
  updatedBy    String?

  request        PurchaseRequest? @relation(fields: [requestId], references: [id])

  partner Partner? @relation("PurchaseOrder_partner", fields: [partnerId], references: [id], onDelete: Restrict)
  branch  Branch?  @relation("PurchaseOrder_branch", fields: [branchId], references: [id], onDelete: SetNull)

  @@unique([organizationId, orderNumber])
  @@index([organizationId, partnerId])
  @@index([organizationId, status])
  @@index([organizationId, orderDate])
}

model PurchaseOrderLine {
  id              String   @id @default(uuid())
  organizationId  String
  purchaseOrderId String
  productId       String?
  description     String
  quantity        Decimal  @db.Decimal(20, 6)
  receivedQuantity Decimal @default(0) @db.Decimal(20, 6)  // running total
  billedQuantity   Decimal @default(0) @db.Decimal(20, 6)
  unitOfMeasureId String?
  unitPrice       Decimal  @db.Decimal(20, 6)
  taxRate         Decimal  @default(0) @db.Decimal(9, 6)
  taxId           String?
  subtotal        Decimal  @default(0) @db.Decimal(20, 6)
  lineNumber      Int      @default(0)
  notes           String?

  order    PurchaseOrder       @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receipts GoodsReceiptLine[]

  @@index([organizationId, purchaseOrderId])
}

/// A goods receipt note — what was actually received against a PO. Each GRN
/// line references the PO line it fulfilled. Posting the GRN issues stock-in
/// moves to the warehouse via the existing StockService.receive().
model GoodsReceiptNote {
  id              String             @id @default(uuid())
  organizationId  String
  receiptNumber   String
  purchaseOrderId String?
  partnerId       String?
  branchId        String?
  warehouseId     String?  // location where goods arrived
  receivedAt      DateTime           @default(now())
  status          GoodsReceiptStatus @default(draft)
  notes           String?
  postedAt        DateTime?
  postedById      String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  lines  GoodsReceiptLine[]
  order  PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  warehouse InventoryLocation? @relation(fields: [warehouseId], references: [id])
  branch  Branch?           @relation("GoodsReceipt_branch", fields: [branchId], references: [id], onDelete: SetNull)
  createdBy String?
  updatedBy String?

  @@unique([organizationId, receiptNumber])
  @@index([organizationId, purchaseOrderId])
  @@index([organizationId, status])
}

model GoodsReceiptLine {
  id               String   @id @default(uuid())
  organizationId   String
  goodsReceiptId   String
  purchaseOrderLineId String?
  productId        String?
  description      String
  quantity         Decimal  @db.Decimal(20, 6)
  unitCost         Decimal  @default(0) @db.Decimal(20, 6)
  batchNumber      String?
  expiryDate       DateTime?
  notes            String?
  lineNumber       Int      @default(0)

  receipt GoodsReceiptNote @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  poLine  PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id])

  @@index([organizationId, goodsReceiptId])
}

/// Links a vendor bill (Document of type vendor_bill) to one or more POs. A
/// single bill can be split across POs (e.g. consolidated monthly statement).
model VendorBillLink {
  id             String   @id @default(uuid())
  organizationId String
  vendorBillId   String  // -> Document.id
  purchaseOrderId String
  amount         Decimal  @db.Decimal(20, 6)  // portion of the bill allocated to this PO
  notes          String?
  createdAt      DateTime @default(now())

  order PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([organizationId, vendorBillId])
  @@index([organizationId, purchaseOrderId])
  @@unique([vendorBillId, purchaseOrderId])
}

/// Computed three-way match result per PO line. Updated whenever a GRN is
/// posted or a bill is linked. Status determines whether AP can post the bill.
model ThreeWayMatch {
  id                String      @id @default(uuid())
  organizationId    String
  purchaseOrderId   String
  purchaseOrderLineId String
  productId         String?
  /// Quantities snapshot at last computation.
  orderedQuantity   Decimal     @db.Decimal(20, 6)
  receivedQuantity  Decimal     @default(0) @db.Decimal(20, 6)
  billedQuantity    Decimal     @default(0) @db.Decimal(20, 6)
  /// Price snapshot.
  orderedUnitPrice  Decimal     @db.Decimal(20, 6)
  billedUnitPrice   Decimal?    @db.Decimal(20, 6)
  /// Variances (positive = over-billed/over-received).
  quantityVariance  Decimal     @default(0) @db.Decimal(20, 6)
  priceVariance     Decimal     @default(0) @db.Decimal(20, 6)
  /// Computed: matched / partial / mismatch / blocked.
  status            MatchStatus @default(pending)
  /// Variance threshold per org (absolute quantity + price %). When the
  /// variance exceeds the threshold, the bill cannot be posted without
  /// explicit approval (status=blocked).
  thresholdExceeded Boolean     @default(false)
  notes             String?
  lastCheckedAt     DateTime    @default(now())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  order PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@unique([purchaseOrderLineId])
  @@index([organizationId, purchaseOrderId])
  @@index([organizationId, status])
}

/// Debit note — issued to a customer (or received from a supplier) to
/// INCREASE the amount owed. Use cases:
///   - Customer underpaid → debit note increases their AR
///   - Supplier overcharged → supplier-issued debit note reduces our AP
/// The direction is "outbound" when WE issue (customer AR +), "inbound" when
/// we RECEIVE one (vendor AP +).
model DebitNote {
  id              String         @id @default(uuid())
  organizationId  String
  noteNumber      String
  /// 'outbound' = we issued to a customer (increases AR)
  /// 'inbound'  = received from a supplier (increases AP / decreases expense)
  direction       String         @default("outbound")
  partnerId       String
  /// Optional: linked customer invoice (outbound) or vendor bill (inbound)
  documentId      String?
  reason          DebitNoteReason @default(other)
  reasonNote      String?
  issueDate       DateTime       @default(now())
  currencyCode    String         @default("USD")
  exchangeRate    Decimal        @default(1) @db.Decimal(18, 8)
  subtotal        Decimal        @default(0) @db.Decimal(20, 6)
  taxAmount       Decimal        @default(0) @db.Decimal(20, 6)
  totalAmount     Decimal        @default(0) @db.Decimal(20, 6)
  status          String         @default("draft")  // draft | posted | cancelled
  postedAt        DateTime?
  postedById      String?
  notes           String?
  customFields    Json           @default("{}")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  lines  DebitNoteLine[]
  partner Partner?        @relation("DebitNote_partner", fields: [partnerId], references: [id], onDelete: Restrict)
  createdBy String?
  updatedBy String?

  @@unique([organizationId, noteNumber])
  @@index([organizationId, partnerId])
  @@index([organizationId, direction, status])
}

model DebitNoteLine {
  id              String   @id @default(uuid())
  organizationId  String
  debitNoteId     String
  productId       String?
  description     String
  quantity        Decimal  @db.Decimal(20, 6)
  unitPrice       Decimal  @db.Decimal(20, 6)
  taxId           String?
  taxAmount       Decimal  @default(0) @db.Decimal(20, 6)
  subtotal        Decimal  @default(0) @db.Decimal(20, 6)
  total           Decimal  @default(0) @db.Decimal(20, 6)
  lineNumber      Int      @default(0)
  notes           String?

  debitNote DebitNote @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)

  @@index([organizationId, debitNoteId])
}

// =============================================================================
// Phase F.6 — Push notification subscriptions (web push)
// =============================================================================

model PushSubscription {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  /// Web Push endpoint URL (from PushSubscription.endpoint).
  endpoint       String   @unique
  p256dh         String
  auth           String
  userAgent      String?
  createdAt      DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  revokedAt      DateTime?

  @@index([organizationId, userId])
}

// =============================================================================
// Phase F.6 — Audit log persistence helpers (immutable journal event log)
// =============================================================================

/// A non-undoable ledger of all material domain events. Backed by an
/// append-only Postgres table (no UPDATE / DELETE allowed at the DB level
/// via a trigger installed in the migration). Separate from AuditLog because
/// AuditLog is fine for UI display; this table is the SOX / IFRS audit-trail.
model DomainEventLog {
  id             BigInt   @id @default(autoincrement())
  organizationId String
  eventName      String
  entityType     String
  entityId       String
  actorId        String?
  payload        Json
  occurredAt     DateTime @default(now())

  @@index([organizationId, occurredAt])
  @@index([organizationId, entityType, entityId])
}

// =============================================================================
// Phase F.7 — CRM pipeline (deals, activities, tasks)
// =============================================================================

enum DealStage {
  lead
  qualified
  proposal
  negotiation
  won
  lost
}

enum ActivityType {
  call
  email
  meeting
  note
  task
  deal_stage_change
}

enum TaskStatus {
  todo
  in_progress
  done
  cancelled
}

/// A deal in the sales pipeline. Linked to a customer Partner; optional PO/Invoice
/// links can be added later via customFields.
model Deal {
  id             String     @id @default(uuid())
  organizationId String
  name           String
  partnerId      String
  ownerId        String?    // User.id of the salesperson
  stage          DealStage  @default(lead)
  amount         Decimal    @default(0) @db.Decimal(20, 6)
  currencyCode   String     @default("USD")
  expectedClose  DateTime?
  notes          String?
  customFields   Json       @default("{}")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  partner Partner?     @relation("PartnerDeals", fields: [partnerId], references: [id], onDelete: Restrict)
  activities Activity[] @relation("DealActivities")

  @@index([organizationId, stage])
  @@index([organizationId, partnerId])
  @@index([organizationId, ownerId])
}

/// A logged activity: call, email, meeting, note, task, deal stage change.
/// Universal timeline that powers the customer 360 view.
model Activity {
  id             String       @id @default(uuid())
  organizationId String
  type           ActivityType
  /// Free-form polymorphic subject: deal, partner, invoice, etc.
  subjectType    String?
  subjectId      String?
  dealId         String?
  partnerId      String?
  /// When this activity happened (user-entered for past activities).
  occurredAt     DateTime     @default(now())
  duration       Int?         // minutes (for calls/meetings)
  title          String
  body           String?
  completed      Boolean      @default(false)
  completedAt    DateTime?
  /// Optional task deadline when type='task'.
  dueAt          DateTime?
  status         TaskStatus   @default(todo)
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  deal Deal? @relation("DealActivities", fields: [dealId], references: [id], onDelete: Cascade)
  partner Partner? @relation("PartnerActivities", fields: [partnerId], references: [id], onDelete: SetNull)

  @@index([organizationId, subjectType, subjectId])
  @@index([organizationId, dealId])
  @@index([organizationId, partnerId])
  @@index([organizationId, dueAt])
  @@index([organizationId, status])
}

// ============================================================================
// POS Phase T1 — Tables Management (ADR-012).
//
// A PosTable is a physical seat (e.g. "Table 7 / VIP 01"). A PosTableOrder
// is the live link between a table and the open Document(s) currently being
// rung up on it; when the sale is tendered the Document is closed and the
// PosTableOrder row is marked closed. PosTableReservation captures bookings
// (with party size + time window) and drives automatic status flips from
// 'available' → 'reserved' → 'occupied'.
//
// Money still flows through `Document` / `Payment` / `KitchenTicket` — these
// three tables are operational metadata only. Hard delete is forbidden;
// `active=false` is the archive marker so history / audit stays intact.
// ============================================================================

enum PosTableStatus {
  available
  occupied
  reserved
  dirty
  out_of_service
}

enum PosTableShape {
  square
  rectangle
  circle
}

enum PosTableZone {
  indoor
  outdoor
  terrace
  vip
  garden
  bar
  custom
}

enum PosReservationStatus {
  pending
  seated
  completed
  cancelled
  no_show
}

/// A physical table or seat group in the venue. Lifecycle: status field.
/// Soft-archive via `active=false`; rows are NEVER hard-deleted (FK from
/// PosTableOrder / PosTableReservation is `onDelete: Restrict`).
model PosTable {
  id                  String         @id @default(uuid())
  organizationId      String
  /// Human display label, e.g. "Table 1", "VIP 01", "Patio 3".
  name                String
  /// Stable, cashier-readable identifier. Unique per org — the server uses
  /// this for "T<n>" badges in the terminal UI.
  number              Int
  /// Number of seats (chairs). 0 = standing / counter spot.
  seats               Int            @default(2)
  /// Where the table sits. `customZone` is filled in only when zone='custom'.
  zone                PosTableZone   @default(indoor)
  customZone          String?
  /// Floor-plan geometry. Persisted so the layout survives a reload; the
  /// visual editor (next iteration) reads + writes these columns.
  shape               PosTableShape  @default(square)
  posX                Int            @default(40)
  posY                Int            @default(40)
  width               Int            @default(120)
  height              Int            @default(120)
  /// Current lifecycle state. Driven by PosTablesService; auto-flipped by
  /// reservations (pending → reserved) and by payment (occupied → dirty).
  status              PosTableStatus @default(available)
  notes               String?
  active              Boolean        @default(true)
  /// Waiter responsible for this table (free-form assignment; null = pool).
  assignedWaiterId    String?
  /// Self-FK: when this table was merged into another, points to the target
  /// table. `null` when not merged.
  mergedIntoId        String?
  mergedAt            DateTime?
  mergedById          String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  createdBy           String?
  updatedBy           String?

  mergedInto PosTable?            @relation("PosTableMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom PosTable[]           @relation("PosTableMerge")
  orders     PosTableOrder[]
  reservations PosTableReservation[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, zone])
  @@index([organizationId, active])
}

/// Live link between a table and the open sales-invoice being rung up on it.
/// One open sale == one row. `closedAt` is set when the Document posts so
/// reports can compute occupancy time. `@@unique([tableId, documentId])`
/// guarantees we can't double-link the same invoice.
model PosTableOrder {
  id              String    @id @default(uuid())
  organizationId  String
  tableId         String
  documentId      String
  /// Snapshot of customer info shown in the table picker (e.g. "Sarah, 4 pax").
  /// Not a hard FK — the customer may be a walk-in (no Partner record).
  customerName    String?
  guestCount      Int?
  /// Wall-clock the table was opened (first item rang). Used by reports for
  /// "average dining time".
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  /// Free-form waiter / cashier note shown in the order panel.
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?

  table    PosTable @relation(fields: [tableId], references: [id], onDelete: Restrict)
  document Document @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@unique([tableId, documentId])
  @@index([organizationId])
  @@index([organizationId, tableId, closedAt])
  @@index([organizationId, documentId])
  @@index([organizationId, openedAt])
}

/// A booking. When `status='seated'` the linked table flips to OCCUPIED and
/// an empty Document is opened (no lines yet) so the cashier can start ringing.
/// The reservation worker flips `pending → no_show` after a 30-minute grace.
model PosTableReservation {
  id                String              @id @default(uuid())
  organizationId    String
  tableId           String
  customerName      String
  phone             String?
  email             String?
  partySize         Int                 @default(2)
  /// Reservation start (guests expected to arrive).
  startAt           DateTime
  /// Reservation end (table must be freed for the next booking).
  endAt             DateTime
  status            PosReservationStatus @default(pending)
  notes             String?
  /// When the guest was seated; null until then.
  seatedAt          DateTime?
  /// Set when the guest is flagged as no-show by the worker.
  noShowAt          DateTime?
  cancelledAt       DateTime?
  /// Optional FK to the Document that was opened when the reservation was seated.
  /// Lets the cashier jump from the reservation list straight to the open ticket.
  seatedDocumentId  String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdBy         String?
  updatedBy         String?

  table PosTable @relation(fields: [tableId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([organizationId, tableId])
  @@index([organizationId, status, startAt])
  @@index([organizationId, startAt])
}
