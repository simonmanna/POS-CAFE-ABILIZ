# ----- Database -----
# The bundled docker-compose Postgres is published on host port 5433
# (to avoid clashing with a locally-installed PostgreSQL on 5432).
DATABASE_URL="postgresql://cafe-pos:cafe-pos@localhost:5433/cafe-pos?schema=public"

# ----- API -----
PORT=3000
NODE_ENV=development
# Comma-separated list of allowed web origins for CORS
CORS_ORIGINS="http://localhost:5173"

# ----- Auth (REQUIRED, 32+ chars; refuse-to-start guard enforces) -----
JWT_ACCESS_SECRET="dev-access-secret-must-be-at-least-32-chars"
JWT_REFRESH_SECRET="dev-refresh-secret-must-be-at-least-32-chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
MFA_ISSUER="Cafe POS"

# ----- Web (Vite) -----
VITE_API_URL="http://localhost:3000"

# ----- Storage -----
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./var/uploads"
UPLOAD_MAX_BYTES="26214400"

# ----- Body limit -----
BODY_LIMIT="2mb"

# ----- SMTP (optional — notifications fall back to log if unset) -----
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="user"
# SMTP_PASS="pass"
# SMTP_FROM="no-reply@example.com"

# ----- Twilio SMS (optional) -----
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM=""

# ----- Redis (optional — required for multi-instance deploys) -----
# REDIS_URL="redis://localhost:6379"

# ----- Logging -----
LOG_LEVEL="info"
