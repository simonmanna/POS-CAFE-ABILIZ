{
  "name": "generic-erp",
  "version": "0.0.0",
  "private": true,
  "description": "Modular ERP platform (modular monolith). Phase 0 (kernel) + Phase 1 (master data).",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "shared:build": "pnpm --filter @erp/shared build",
    "dev:api": "pnpm --filter @erp/shared build && pnpm --filter @erp/api start:dev",
    "dev:web": "pnpm --filter @erp/web dev",
    "db:up": "docker compose up -d db",
    "db:generate": "pnpm --filter @erp/api db:generate",
    "db:migrate": "pnpm --filter @erp/api db:migrate",
    "db:seed": "pnpm --filter @erp/api db:seed",
    "db:reset": "pnpm --filter @erp/api db:reset",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "@nestjs/core"
    ]
  }
}
