// =============================================================================
// Generic ERP Platform — Prisma schema (Phase 0 kernel + Phase 1 master data)
//
// Conventions (see docs/adr):
//  - Tenant tables carry `organizationId` (ADR-004). Tenancy is enforced in the
//    app layer by a Prisma Client Extension + AsyncLocalStorage context.
//  - Standard columns on business tables: id, organizationId, createdAt,
//    updatedAt, createdBy, updatedBy, deletedAt (soft delete).
//  - System/global tables (Organization, Permission, Currency) have NO
//    organizationId.
//  - Industry concepts (Student/Patient/...) do NOT appear here (ADR-008).
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------- Enums ----------------------------------------

enum OrganizationStatus {
  active
  suspended
  archived
}

enum PartnerStatus {
  active
  inactive
  archived
}

enum ProductType {
  stockable
  consumable
  service
  fee
  subscription
  asset
}

enum TaxType {
  vat
  gst
  sales_tax
  withholding
}

enum FiscalPeriodStatus {
  open
  closed
  locked
}

enum AddressType {
  billing
  shipping
  office
  branch
  home
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  approve
  reject
  post
  cancel
  receive
  issue
  adjust
  transfer
}

// ------------------------- System / global tables ---------------------------

/// Tenant root. This table IS the tenant, so it has no organizationId.
model Organization {
  id           String             @id @default(uuid())
  code         String             @unique
  name         String
  timezone     String             @default("UTC")
  currencyCode String             @default("USD")
  status       OrganizationStatus @default(active)
  settings     Json               @default("{}")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?
}

/// Global permission catalog (resource:action). Seeded from @erp/shared.
model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())
}

/// Global ISO-4217 currency catalog (ADR-004: currency is global).
model Currency {
  id            String   @id @default(uuid())
  code          String   @unique
  symbol        String
  name          String
  decimalPlaces Int      @default(2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ------------------------------- Auth / RBAC --------------------------------

model User {
  id           String    @id @default(uuid())
  organizationId String
  email        String
  passwordHash String
  firstName    String
  lastName     String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  roles         Role[]         @relation("UserRoles")
  refreshTokens RefreshToken[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Role {
  id           String    @id @default(uuid())
  organizationId String
  name         String
  description  String?
  isSystem     Boolean   @default(false)
  permissions  String[]  @default([])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  users User[] @relation("UserRoles")

  @@unique([organizationId, name])
  @@index([organizationId])
}

model RefreshToken {
  id           String    @id @default(uuid())
  organizationId String
  userId       String
  tokenHash    String
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
}

// ------------------------------- Kernel -------------------------------------

model AuditLog {
  id           String      @id @default(uuid())
  organizationId String
  entity       String
  entityId     String
  action       AuditAction
  oldValues    Json?
  newValues    Json?
  actorId      String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())

  @@index([organizationId, entity, entityId])
  @@index([organizationId, createdAt])
}

/// Settings at system (organizationId null), organization, or module scope.
model Setting {
  id           String   @id @default(uuid())
  organizationId String?
  scope        String   @default("organization")
  module       String?
  key          String
  value        Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([organizationId, scope, key])
  @@index([organizationId])
}

// ---------------------------- Master data -----------------------------------

model Partner {
  id           String        @id @default(uuid())
  organizationId String
  code         String
  name         String
  isCompany    Boolean       @default(false)
  isCustomer   Boolean       @default(false)
  isSupplier   Boolean       @default(false)
  isEmployee   Boolean       @default(false)
  email        String?
  phone        String?
  website      String?
  taxNumber    String?
  receivableAccountId String?
  payableAccountId    String?
  status       PartnerStatus @default(active)
  categoryId   String?
  notes        String?
  customFields Json          @default("{}")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  category  PartnerCategory? @relation(fields: [categoryId], references: [id])
  contacts  Contact[]
  addresses Address[]
  documents Document[]
  payments  Payment[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, name])
}

model PartnerCategory {
  id           String    @id @default(uuid())
  organizationId String
  name         String
  parentId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  parent   PartnerCategory?  @relation("PartnerCategoryTree", fields: [parentId], references: [id])
  children PartnerCategory[] @relation("PartnerCategoryTree")
  partners Partner[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Contact {
  id           String    @id @default(uuid())
  organizationId String
  partnerId    String
  firstName    String
  lastName     String?
  position     String?
  email        String?
  phone        String?
  isPrimary    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([partnerId])
}

model Address {
  id           String      @id @default(uuid())
  organizationId String
  partnerId    String
  type         AddressType @default(billing)
  line1        String
  line2        String?
  city         String?
  state        String?
  postalCode   String?
  country      String?
  isPrimary    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([partnerId])
}

model Product {
  id           String      @id @default(uuid())
  organizationId String
  code         String
  sku          String?
  name         String
  description  String?
  productType  ProductType @default(stockable)
  categoryId   String?
  uomId        String?
  taxId        String?
  salesPrice   Decimal?    @db.Decimal(18, 6)
  costPrice    Decimal?    @db.Decimal(18, 6)
  trackInventory Boolean   @default(true)
  batchTracking Boolean    @default(false)
  minQuantity  Decimal     @default(0) @db.Decimal(20, 6)
  isActive     Boolean     @default(true)
  customFields Json        @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  category ProductCategory? @relation(fields: [categoryId], references: [id])
  uom      UnitOfMeasure?   @relation(fields: [uomId], references: [id])
  tax      Tax?             @relation(fields: [taxId], references: [id])
  stockItems   StockItem[]
  stockBatches InventoryBatch[]
  stockLedger  InventoryLedger[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, name])
}

model ProductCategory {
  id           String    @id @default(uuid())
  organizationId String
  name         String
  parentId     String?
  incomeAccountId  String?
  expenseAccountId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  parent   ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("ProductCategoryTree")
  products Product[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model UnitOfMeasure {
  id           String    @id @default(uuid())
  organizationId String
  code         String
  name         String
  category     String    @default("unit")
  ratio        Decimal   @default(1) @db.Decimal(18, 6)
  isBase       Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  products Product[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model Tax {
  id           String    @id @default(uuid())
  organizationId String
  name         String
  code         String?
  type         TaxType   @default(vat)
  rate         Decimal   @default(0) @db.Decimal(9, 6)
  isInclusive  Boolean   @default(false)
  isCompound   Boolean   @default(false)
  accountId    String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  products Product[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model FiscalPeriod {
  id           String             @id @default(uuid())
  organizationId String
  name         String
  startDate    DateTime
  endDate      DateTime
  status       FiscalPeriodStatus @default(open)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Branch {
  id           String    @id @default(uuid())
  organizationId String
  code         String
  name         String
  timezone     String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime?

  @@unique([organizationId, code])
  @@index([organizationId])
}

// =============================================================================
// Phase 2 — General Ledger engine
// =============================================================================

enum AccountType {
  asset
  liability
  equity
  revenue
  expense
  cost_of_goods_sold
  bank
  cash
  receivable
  payable
  tax
  contra_asset
  contra_liability
}

enum JournalType {
  general
  sales
  purchase
  cash
  bank
  adjustment
  opening
  closing
}

enum JournalEntryStatus {
  draft
  posted
  reversed
}

/// Chart of accounts. `isGroup` accounts are summary nodes and cannot be posted to.
model Account {
  id              String      @id @default(uuid())
  organizationId  String
  code            String
  name            String
  accountType     AccountType
  parentAccountId String?
  currencyId      String?
  isGroup         Boolean     @default(false)
  isActive        Boolean     @default(true)
  description     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  createdBy       String?
  updatedBy       String?
  deletedAt       DateTime?

  parent        Account?       @relation("AccountTree", fields: [parentAccountId], references: [id])
  children      Account[]      @relation("AccountTree")
  journalLines  JournalLine[]
  documentLines DocumentLine[]
  bankAccount   BankAccount?

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, accountType])
}

model Journal {
  id                     String      @id @default(uuid())
  organizationId         String
  code                   String
  name                   String
  journalType            JournalType @default(general)
  defaultDebitAccountId  String?
  defaultCreditAccountId String?
  sequencePrefix         String?
  isActive               Boolean     @default(true)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  createdBy              String?
  updatedBy              String?
  deletedAt              DateTime?

  entries JournalEntry[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

/// Immutable once posted. Corrections are made via reversing entries (ADR-009).
model JournalEntry {
  id              String             @id @default(uuid())
  organizationId  String
  journalId       String
  entryNumber     String
  postingDate     DateTime
  description     String?
  status          JournalEntryStatus @default(draft)
  currencyId      String?
  sourceType      String?
  sourceId        String?
  reversedEntryId String? // the reversal entry that voids this one
  reversalOfId    String? // set when this entry IS a reversal of another
  postedAt        DateTime?
  postedBy        String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       String?

  journal Journal       @relation(fields: [journalId], references: [id])
  lines   JournalLine[]

  @@unique([organizationId, entryNumber])
  @@index([organizationId])
  @@index([organizationId, postingDate])
  @@index([sourceType, sourceId])
}

model JournalLine {
  id             String   @id @default(uuid())
  organizationId String
  journalEntryId String
  accountId      String
  partnerId      String?
  description    String?
  debit          Decimal  @default(0) @db.Decimal(20, 6)
  credit         Decimal  @default(0) @db.Decimal(20, 6)
  currencyId     String?
  exchangeRate   Decimal  @default(1) @db.Decimal(18, 8)
  baseDebit      Decimal  @default(0) @db.Decimal(20, 6)
  baseCredit     Decimal  @default(0) @db.Decimal(20, 6)
  lineNumber     Int      @default(0)
  createdAt      DateTime @default(now())

  entry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([organizationId])
  @@index([journalEntryId])
  @@index([organizationId, accountId])
}

/// Org-level account determination defaults (key -> account). See ADR-009.
model AccountMapping {
  id             String    @id @default(uuid())
  organizationId String
  key            String
  accountId      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, key])
  @@index([organizationId])
}

/// Atomic, concurrency-safe numbering (Odoo ir.sequence). Shared by journals & documents.
model Sequence {
  id             String   @id @default(uuid())
  organizationId String
  key            String
  prefix         String   @default("")
  padding        Int      @default(5)
  nextValue      Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
}

model BankAccount {
  id             String    @id @default(uuid())
  organizationId String
  accountId      String    @unique
  name           String
  bankName       String?
  accountNumber  String?
  currencyId     String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?
  updatedBy      String?
  deletedAt      DateTime?

  account Account @relation(fields: [accountId], references: [id])

  @@index([organizationId])
}

// =============================================================================
// Phase 3 — Document framework + Accounts Receivable
// =============================================================================

enum DocumentType {
  sales_invoice
  credit_note
  vendor_bill
  debit_note
  proforma_invoice
}

enum DocumentStatus {
  draft
  submitted
  approved
  posted
  paid
  cancelled
}

enum PaymentStatus {
  not_paid
  partial
  paid
  overpaid
}

enum PaymentDirection {
  inbound
  outbound
}

/// Universal financial document. POS/School/Hotel etc. create these; the
/// accounting engine posts them. Residual lives here (NOT a separate ledger).
model Document {
  id                 String         @id @default(uuid())
  organizationId     String
  documentNumber     String
  documentType       DocumentType   @default(sales_invoice)
  partnerId          String
  currencyId         String?
  exchangeRate       Decimal        @default(1) @db.Decimal(18, 8)
  issueDate          DateTime
  dueDate            DateTime?
  status             DocumentStatus @default(draft)
  reference          String?
  notes              String?
  subtotal           Decimal        @default(0) @db.Decimal(20, 6)
  discountTotal      Decimal        @default(0) @db.Decimal(20, 6)
  taxAmount          Decimal        @default(0) @db.Decimal(20, 6)
  totalAmount        Decimal        @default(0) @db.Decimal(20, 6)
  amountPaid         Decimal        @default(0) @db.Decimal(20, 6)
  amountResidual     Decimal        @default(0) @db.Decimal(20, 6)
  paymentStatus      PaymentStatus  @default(not_paid)
  journalEntryId     String?
  reversedDocumentId String? // credit note -> original invoice
  sourceType         String?
  sourceId           String?
  postedAt           DateTime?
  postedBy           String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  createdBy          String?
  updatedBy          String?

  partner     Partner             @relation(fields: [partnerId], references: [id])
  lines       DocumentLine[]
  allocations PaymentAllocation[]

  @@unique([organizationId, documentNumber])
  @@index([organizationId])
  @@index([organizationId, partnerId])
  @@index([organizationId, documentType, status])
}

model DocumentLine {
  id              String  @id @default(uuid())
  organizationId  String
  documentId      String
  productId       String?
  accountId       String?
  description     String
  quantity        Decimal @default(1) @db.Decimal(20, 6)
  unitPrice       Decimal @default(0) @db.Decimal(20, 6)
  discountPercent Decimal @default(0) @db.Decimal(9, 4)
  taxId           String?
  subtotal        Decimal @default(0) @db.Decimal(20, 6)
  taxAmount       Decimal @default(0) @db.Decimal(20, 6)
  total           Decimal @default(0) @db.Decimal(20, 6)
  lineNumber      Int     @default(0)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  account  Account? @relation(fields: [accountId], references: [id])

  @@index([organizationId])
  @@index([documentId])
}

model Payment {
  id                String           @id @default(uuid())
  organizationId    String
  paymentNumber     String
  direction         PaymentDirection @default(inbound)
  partnerId         String
  paymentDate       DateTime
  paymentMethod     String           @default("cash")
  journalId         String?
  accountId         String?
  currencyId        String?
  exchangeRate      Decimal          @default(1) @db.Decimal(18, 8)
  amount            Decimal          @default(0) @db.Decimal(20, 6)
  allocatedAmount   Decimal          @default(0) @db.Decimal(20, 6)
  unallocatedAmount Decimal          @default(0) @db.Decimal(20, 6)
  reference         String?
  status            DocumentStatus   @default(posted)
  journalEntryId    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  createdBy         String?
  updatedBy         String?

  partner     Partner             @relation(fields: [partnerId], references: [id])
  allocations PaymentAllocation[]

  @@unique([organizationId, paymentNumber])
  @@index([organizationId])
  @@index([organizationId, partnerId])
}

model PaymentAllocation {
  id             String   @id @default(uuid())
  organizationId String
  paymentId      String
  documentId     String
  amount         Decimal  @default(0) @db.Decimal(20, 6)
  createdAt      DateTime @default(now())

  payment  Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id])

  @@index([organizationId])
  @@index([paymentId])
  @@index([documentId])
}

// =============================================================================
// Phase 4 — Inventory (stock of Products; optional batch/expiry, kept simple)
// =============================================================================

enum LocationType {
  warehouse
  store
  virtual
}

enum StockMoveType {
  receipt
  issue
  adjustment_in
  adjustment_out
  transfer_in
  transfer_out
  opening_balance
}

model InventoryLocation {
  id             String       @id @default(uuid())
  organizationId String
  code           String
  name           String
  type           LocationType @default(warehouse)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      String?
  updatedBy      String?
  deletedAt      DateTime?

  stockItems    StockItem[]
  batches       InventoryBatch[]
  ledgerEntries InventoryLedger[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

/// On-hand quantity per product per location (the "quant").
model StockItem {
  id             String   @id @default(uuid())
  organizationId String
  productId      String
  locationId     String
  quantity       Decimal  @default(0) @db.Decimal(20, 6)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product  Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  location InventoryLocation @relation(fields: [locationId], references: [id])

  @@unique([organizationId, productId, locationId])
  @@index([organizationId])
  @@index([productId])
  @@index([locationId])
}

/// Optional batch/lot with optional expiry — only used when product.batchTracking.
model InventoryBatch {
  id             String    @id @default(uuid())
  organizationId String
  productId      String
  locationId     String
  batchNumber    String
  quantity       Decimal   @default(0) @db.Decimal(20, 6)
  unitCost       Decimal?  @db.Decimal(20, 6)
  expiryDate     DateTime?
  receivedAt     DateTime  @default(now())
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  location      InventoryLocation @relation(fields: [locationId], references: [id])
  ledgerEntries InventoryLedger[]

  @@index([organizationId])
  @@index([productId, locationId])
  @@index([expiryDate])
}

/// Immutable stock ledger — every movement (receipt/issue/adjustment/transfer).
model InventoryLedger {
  id             String        @id @default(uuid())
  organizationId String
  ledgerCode     String
  productId      String
  locationId     String
  batchId        String?
  type           StockMoveType
  quantityChange Decimal       @db.Decimal(20, 6)
  balanceAfter   Decimal       @db.Decimal(20, 6)
  unitCost       Decimal       @default(0) @db.Decimal(20, 6)
  totalValue     Decimal       @default(0) @db.Decimal(20, 6)
  referenceType  String?
  referenceId    String?
  notes          String?
  performedBy    String?
  createdAt      DateTime      @default(now())

  product  Product           @relation(fields: [productId], references: [id])
  location InventoryLocation @relation(fields: [locationId], references: [id])
  batch    InventoryBatch?   @relation(fields: [batchId], references: [id])

  @@unique([organizationId, ledgerCode])
  @@index([organizationId])
  @@index([productId])
  @@index([locationId])
  @@index([organizationId, createdAt])
}
